EZTOR_TOKEN=
EZTOR_UNIQEABC=dorg
EZTOR_TIMEZONE=Asia/Jerusalem

# Optional. Leave the defaults if you want the bot to target Dor and the
# men's haircut service.
# EZTOR_TARGET_EMPLOYEE_NAME=
# EZTOR_TARGET_TREATMENT_NAME=

# Strongly recommended for full booking support. If this is blank, the bot can
# still derive the user id from data/user-profile.json when that file exists.
EZTOR_USER_ID=
EZTOR_USER_PROFILE_FILE=./data/user-profile.json
EZTOR_ORDER_TEMPLATE_FILE=./data/order-template.json

EZTOR_SCAN_INTERVAL_MINUTES=15
EZTOR_MIDNIGHT_BURST_MINUTES=20
EZTOR_DESIRED_WEEKDAY=2
EZTOR_DESIRED_HOUR=18
EZTOR_DESIRED_MINUTE=0
EZTOR_FALLBACK_AFTER_HOUR=16
EZTOR_TARGET_LEAD_DAYS=30

EZTOR_DRY_RUN=true
EZTOR_STATE_FILE=./data/state.json
EZTOR_DISCOVERY_FILE=./data/discovery.json

# Token renewal alerts. The bot will alert only on auth failures, and will
# repeat the alert after this many hours if the token is still invalid.
EZTOR_ALERT_REPEAT_HOURS=12
EZTOR_TOKEN_RENEW_AFTER_DAYS=25

# Email alerts via Resend
# RESEND_API_KEY=
# EZTOR_ALERT_EMAIL_FROM=
# EZTOR_ALERT_EMAIL_TO=

# Phone alerts via Telegram bot
# EZTOR_TELEGRAM_BOT_TOKEN=
# EZTOR_TELEGRAM_CHAT_ID=

# Phone alerts via Twilio SMS
# EZTOR_TWILIO_ACCOUNT_SID=
# EZTOR_TWILIO_AUTH_TOKEN=
# EZTOR_TWILIO_FROM_NUMBER=
# EZTOR_TWILIO_TO_NUMBER=
